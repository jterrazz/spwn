#!/usr/bin/env python3
"""x-fetch — read-only X scraper backed by twscrape, used by the gate's
XElement. Reads cookies from /credentials/x/cookies.json (written by
the spwn-cookie-sync browser extension), passes them to twscrape's
auth flow, runs one operation, prints the JSON result.

Designed to be invoked per-request by the Go XElement (subprocess).
twscrape's account DB lives at /gate/x/twscrape.db so account state
persists across calls without re-auth churn.

Usage:
  x-fetch fetch-favorites [--limit N]
  x-fetch fetch-account --handle @h [--limit N]
  x-fetch search --query Q [--limit N]
  x-fetch fetch-thread --tweet-id ID

Exit codes:
  0  success — JSON on stdout
  2  bad args
  3  no cookies — actionable hint on stderr
  4  twscrape error — stderr has details
"""

import argparse
import asyncio
import json
import os
import sys
from pathlib import Path

COOKIES_PATH = Path("/credentials/x/cookies.json")
ACCOUNT_DB = Path("/gate/x/twscrape.db")
ACCOUNT_NAME = "spwn-cookie-sync"


def load_cookies():
    if not COOKIES_PATH.exists():
        print(
            "no X cookies on the gate — install the spwn-cookie-sync browser\n"
            "extension and visit x.com once. See `spwn cookie-sync register`.",
            file=sys.stderr,
        )
        sys.exit(3)
    raw = json.loads(COOKIES_PATH.read_text())
    cookies = raw.get("cookies", {})
    if "auth_token" not in cookies or "ct0" not in cookies:
        print(
            "X cookies missing auth_token or ct0 — visit x.com again in your\n"
            "browser to refresh, the extension will re-push.",
            file=sys.stderr,
        )
        sys.exit(3)
    return cookies


async def main():
    p = argparse.ArgumentParser(prog="x-fetch")
    sub = p.add_subparsers(dest="action", required=True)

    f1 = sub.add_parser("fetch-favorites")
    f1.add_argument("--limit", type=int, default=50)

    f2 = sub.add_parser("fetch-account")
    f2.add_argument("--handle", required=True)
    f2.add_argument("--limit", type=int, default=50)

    f3 = sub.add_parser("search")
    f3.add_argument("--query", required=True)
    f3.add_argument("--limit", type=int, default=50)

    f4 = sub.add_parser("fetch-thread")
    f4.add_argument("--tweet-id", required=True)

    args = p.parse_args()

    cookies = load_cookies()
    cookie_str = f"auth_token={cookies['auth_token']}; ct0={cookies['ct0']}"

    ACCOUNT_DB.parent.mkdir(parents=True, exist_ok=True)

    # Lazy import — avoids paying twscrape's import cost when only --help
    # is requested.
    from twscrape import API

    api = API(str(ACCOUNT_DB))

    # Always (re-)set the cookies so a re-pushed cookie file lands here
    # without manual reset.
    await api.pool.add_account(
        ACCOUNT_NAME,
        "<not-used>",  # password not used with cookies
        "<not-used>",  # email not used
        "<not-used>",  # email_password not used
        cookies=cookie_str,
    )

    try:
        if args.action == "fetch-favorites":
            # twscrape: bookmarks of the authenticated user
            uid = (await api.user_by_login(ACCOUNT_NAME))  # placeholder; bookmarks need own user id
            # twscrape exposes `bookmarks(limit)` on API
            items = []
            async for tw in api.bookmarks(limit=args.limit):
                items.append(_tweet_dict(tw))
            print(json.dumps({"items": items, "count": len(items)}))

        elif args.action == "fetch-account":
            handle = args.handle.lstrip("@")
            user = await api.user_by_login(handle)
            if user is None:
                print(json.dumps({"error": f"user @{handle} not found"}))
                sys.exit(0)
            items = []
            async for tw in api.user_tweets(user.id, limit=args.limit):
                items.append(_tweet_dict(tw))
            print(json.dumps({
                "handle": handle,
                "user_id": user.id,
                "items": items,
                "count": len(items),
            }))

        elif args.action == "search":
            items = []
            async for tw in api.search(args.query, limit=args.limit):
                items.append(_tweet_dict(tw))
            print(json.dumps({
                "query": args.query,
                "items": items,
                "count": len(items),
            }))

        elif args.action == "fetch-thread":
            tw = await api.tweet_details(int(args.tweet_id))
            if tw is None:
                print(json.dumps({"error": f"tweet {args.tweet_id} not found"}))
                sys.exit(0)
            print(json.dumps({"tweet": _tweet_dict(tw)}))

    except Exception as e:
        print(f"twscrape error: {e}", file=sys.stderr)
        sys.exit(4)


def _tweet_dict(tw):
    """Reduce a twscrape tweet object to a JSON-friendly dict —
    just the fields agents typically use, not the full GraphQL blob."""
    return {
        "id": str(getattr(tw, "id", "")),
        "url": getattr(tw, "url", None),
        "text": getattr(tw, "rawContent", None) or getattr(tw, "text", None),
        "user": {
            "id": str(getattr(getattr(tw, "user", None), "id", "")),
            "username": getattr(getattr(tw, "user", None), "username", None),
            "displayname": getattr(getattr(tw, "user", None), "displayname", None),
        } if getattr(tw, "user", None) else None,
        "date": str(getattr(tw, "date", "")) if getattr(tw, "date", None) else None,
        "likes": getattr(tw, "likeCount", None),
        "retweets": getattr(tw, "retweetCount", None),
        "replies": getattr(tw, "replyCount", None),
        "in_reply_to": str(getattr(tw, "inReplyToTweetId", "")) if getattr(tw, "inReplyToTweetId", None) else None,
    }


if __name__ == "__main__":
    asyncio.run(main())
