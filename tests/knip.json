{
    "$schema": "https://unpkg.com/knip@6/schema.json",
    "entry": [
        "specs/cli/cli.specification.ts",
        "specs/cli/**/*.test.ts",
        "vitest.config.ts",
        "vitest.smoke.config.ts",
        "oxlint.config.ts",
        "oxfmt.config.ts"
    ],
    "ignoreBinaries": ["make", "pgrep"],
    "ignoreDependencies": ["hono", "@hono/node-server"],
    "project": ["specs/**/*.ts"],
    "ignore": ["specs/fixtures/**", "specs/cli/**/fixtures/**", "specs/cli/**/expected/**"]
}
