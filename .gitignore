# Local agent state
.claude/
.spwn/

# Re-include .claude/ trees under golden-fixture directories so the
# claude-code renderer's output snapshots (settings.json, SKILL.md
# files) are tracked. Without this, the global `.claude/` rule above
# silently strips them and CI fails with "tree has extra
# agents/<name>/.claude/..." against every fixture.
!packages/runtimes/testdata/**/.claude/
!packages/runtimes/testdata/**/.claude/**

# Archives (agent exports etc.)
*.tar.gz
*.tar
*.bak

# Test artifacts scaffolded by e2e runs
tests/spwn/
tests/spwn.yaml
tests/playwright-report/
tests/test-results/

# Mirror of /catalog/ generated by `go:generate` into the Go package
# tree so //go:embed can reach it (embed can't use .. or cross-module
# paths). Source of truth is /catalog/ at the repo root; refresh via
# `make generate` (or `go generate ./packages/dependency/...`).
# Makefile wires `generate` as a prerequisite for both `build` and
# `test`, so any make-driven workflow sees it. Fresh `go build`
# without Make needs one `go generate` first.
/packages/dependency/internal/adapters/spwn/content/
spwn/agents/
