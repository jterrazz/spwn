FROM debian:bookworm-slim
LABEL sh.spwn.image-version="1.0.0"

# Install Docker CLI + Node.js 20 (for Claude Code)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl gnupg && \
    curl -fsSL https://get.docker.com | sh && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    npm install -g @anthropic-ai/claude-code && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Create non-root user for Claude Code (refuses --dangerously-skip-permissions as root)
RUN useradd -m -s /bin/bash architect

# Copy spwn binary (cross-compiled for linux/amd64, provided in build context)
COPY spwn /usr/local/bin/spwn
RUN chmod +x /usr/local/bin/spwn

# Copy Architect identity file
COPY system/architect/ARCHITECT.md /world/ARCHITECT.md

# Copy global agent operating manual and system skills
COPY system/AGENTS.md /world/AGENTS.md
COPY system/skills/ /world/skills/

# Copy architect-specific skills (merged into /world/skills/)
COPY system/architect/skills/ /world/skills/

# Copy default architect stack (overridden by runtime mount)
COPY system/architect/stack.md /world/stack.md

RUN mkdir -p /world && chown -R architect:architect /world

# Container runs as ROOT for file access (bind mounts from host)
# But `docker exec -u architect` is used when running Claude Code
# Shared data dir — mounted from host, accessible to all users
RUN mkdir -p /spwn-data && chmod 777 /spwn-data
ENV SPWN_HOME=/spwn-data
WORKDIR /world

# Entrypoint aligns the architect user's groups with the host's
# docker.sock GID so docker exec -u architect can run docker commands.
COPY entrypoint.sh /usr/local/bin/architect-entrypoint.sh
RUN chmod +x /usr/local/bin/architect-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/architect-entrypoint.sh"]
CMD ["sleep", "infinity"]
