#!/usr/bin/env bash
# pre-spawn hook — runs on the HOST before the world container starts.
#
# Typical uses: warm caches, check env vars, write generated config,
# validate workspace state. Exit non-zero to abort the spawn.
#
# cwd is the project root. Output goes to the user's terminal (stderr
# is nice for banners so it doesn't mix with JSON output modes).
#
# Docs: https://spwn.sh/docs/hooks

set -euo pipefail

echo "[pre-spawn] {{.Name}} is about to wake up in $(pwd)" >&2
