# Agent composition — the source of truth for what this agent needs.
#
# Dependency resolution works like npm:
#   @spwn/<name>       built-in catalog package (compiled into spwn)
#   @<owner>/<name>    future: remote community registry
#   <bare-name>        local package authored under spwn/packages/<name>/
#                      (or spwn/packages/<name>.md for a bare skill)
#
# Catalog refs are pinned in spwn.lock.yaml at the project root. Add
# new ones with `spwn package install @spwn/<name>` (or `spwn pkg`).

name: neo

runtime:
  backend: "@spwn/claude-code"

packages:
  - "@spwn/unix"
  - "@spwn/git"
  - "@spwn/python"
