# Agent composition — the source of truth for what this agent needs.
#
# Dependency resolution works like npm:
#   @spwn/<name>       built-in catalog pack (compiled into spwn)
#   @<owner>/<name>    future: remote community registry
#   <bare-name>        local pack authored under spwn/tools/<name>/
#
# Installed catalog refs are pinned in spwn.lock.yaml at the project
# root. Add new ones with `spwn tool install @spwn/<name>`.

name: neo

runtime:
  backend: "@spwn/claude-code"

tools:
  - "@spwn/unix"
  - "@spwn/git"
  - "@spwn/python"
