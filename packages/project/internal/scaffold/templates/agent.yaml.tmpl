# Agent composition — the source of truth for what this agent needs.
#
# deps: lists external dependencies (catalog packs or GitHub repos).
# skills: / tools: / hooks: list local blocks authored in spwn/.
#
# Resolution:
#   @spwn/<name>                 built-in catalog pack
#   github.com/<owner>/<repo>    third-party pack (git tags as versions)
#   <bare-name>                  local (spwn/skills/, spwn/tools/, spwn/hooks/)

name: neo

runtime:
  backend: "@spwn/claude-code"

deps:
  - "@spwn/unix"
  - "@spwn/git"
  - "@spwn/python"
