{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "echo \"[audit] $CLAUDE_TOOL_INPUT\"",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "echo \"session up\"",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
